theme = Catppuccin Mocha

cursor-style = block
cursor-style-blink = false

background-opacity = 0.8
background-blur = true

font-family = JetBrainsMono Nerd Font Mono
font-family-bold = JetBrainsMono Nerd Font Mono Extra Bold
font-family-bold-italic = JetBrainsMono Nerd Font Mono Extra Bold Italic

font-size = 16

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
